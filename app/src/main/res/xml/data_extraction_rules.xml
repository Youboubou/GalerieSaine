<?xml version="1.0" encoding="utf-8"?>
<!--
    Aucune donnée de l'app n'est incluse dans les sauvegardes ou transferts
    automatiques, pour garantir la confidentialité maximale.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
